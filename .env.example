# --- Database ---
POSTGRES_DB=bakhrushin
POSTGRES_USER=bakhrushin
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg2://bakhrushin:change_me@db:5432/bakhrushin

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Telegram ---
TELEGRAM_BOT_TOKEN=PUT_BOT_TOKEN_HERE
TELEGRAM_CHANNEL=@bakhrushinmuseum_news
# Comma-separated Telegram user IDs allowed to moderate in bot
TELEGRAM_ADMIN_IDS=
# Optional SOCKS5/HTTP proxy for Telegram bot, e.g. socks5://user:pass@host:1080
TELEGRAM_PROXY_URL=

# --- AI ---
# Primary provider selector: openai (default) or any OpenAI-compatible provider label (custom string)
AI_PROVIDER=openai
# API key for selected provider
AI_API_KEY=PUT_OPENAI_API_KEY_HERE
# Base URL for OpenAI-compatible APIs (keep default for OpenAI)
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.4

# Legacy compatibility (optional): if AI_API_KEY/AI_BASE_URL are empty, these will be used
# POLZA_API_KEY=
# POLZA_BASE_URL=https://api.polza.ai/api/v1

# Language used when publishing to Telegram (ru, th, en, es, it)
TG_PUBLISH_LANGUAGE=th
# If true, posts are auto-approved right after AI generation and sent to publish queue
AUTO_PUBLISH_AFTER_AI_SELECTION=false
# If true, posts are auto-translated to TG_PUBLISH_LANGUAGE when needed before auto-approval
AUTO_TRANSLATE_AFTER_AI_SELECTION=true

# --- Cutoffs ---
# Sliding window: do not collect items older than N days (if item date is available)
NEWS_NOT_BEFORE_DAYS=7
# Sliding window: do not run AI summarization for items older than N days (if item date is available)
AI_NOT_BEFORE_DAYS=7
# Optional absolute cutoffs (ISO date/datetime). Used only if *_DAYS is not set.
# NEWS_NOT_BEFORE=2026-02-01
# AI_NOT_BEFORE=2026-02-01

# --- App ---
APP_ENV=prod
APP_BASE_URL=http://localhost:8000
SECRET_KEY=change_me_too
WEB_PASSWORD=your_web_password_here
