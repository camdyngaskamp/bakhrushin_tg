# --- Database ---
POSTGRES_DB=bakhrushin
POSTGRES_USER=bakhrushin
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg2://bakhrushin:change_me@db:5432/bakhrushin

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Telegram ---
TELEGRAM_BOT_TOKEN=PUT_BOT_TOKEN_HERE
TELEGRAM_CHANNEL=@bakhrushinmuseum_news
# Comma-separated Telegram user IDs allowed to moderate in bot
TELEGRAM_ADMIN_IDS=
# Optional SOCKS5/HTTP proxy for Telegram bot, e.g. socks5://user:pass@host:1080
TELEGRAM_PROXY_URL=

# --- AI (polza.ai OpenAI-compatible) ---
POLZA_API_KEY=PUT_POLZA_API_KEY_HERE
# According to polza.ai docs; change if your account provides a different base URL:
POLZA_BASE_URL=https://api.polza.ai/api/v1
AI_MODEL=openai/gpt-4o-mini
AI_TEMPERATURE=0.4

# Language used when publishing to Telegram (ru, th, en, es)
TG_PUBLISH_LANGUAGE=th

# --- Cutoffs ---
# Sliding window: do not collect items older than N days (if item date is available)
NEWS_NOT_BEFORE_DAYS=7
# Sliding window: do not run AI summarization for items older than N days (if item date is available)
AI_NOT_BEFORE_DAYS=7
# Optional absolute cutoffs (ISO date/datetime). Used only if *_DAYS is not set.
# NEWS_NOT_BEFORE=2026-02-01
# AI_NOT_BEFORE=2026-02-01

# --- App ---
APP_ENV=prod
APP_BASE_URL=http://localhost:8000
SECRET_KEY=change_me_too
WEB_PASSWORD=your_web_password_here
